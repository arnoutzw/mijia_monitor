%% =============================================================================
%% FSCMS v2.0 (Mijia Monitor) — UML Diagrams (Mermaid)
%% =============================================================================

%% === Class Diagram ===
classDiagram
    class App {
        +Map~string,SensorState~ sensors
        +BLEPerf blePerf
        +IDBDatabase db
        +boolean scanning
        +boolean advertMode
        +string activeTab
        +object alertCooldowns
        +init()
        +connectDevice()
        +disconnectDevice(id)
        +startAdvertScan()
        +stopAdvertScan()
        +checkAlerts()
        +checkBatteryAlerts()
        +render()
    }

    class SensorState {
        +string id
        +string name
        +BluetoothDevice device
        +BluetoothRemoteGATTServer server
        +BluetoothRemoteGATTCharacteristic customChar
        +BluetoothRemoteGATTCharacteristic otaChar
        +BluetoothRemoteGATTCharacteristic miTempChar
        +number temp
        +number humi
        +number batt
        +number battMv
        +number rssi
        +string firmware
        +string mac
        +number measInterval
        +number advInterval
        +number txPower
        +number storageRate
        +string profileName
        +number lastUpdate
        +boolean isCustom
        +boolean isConnected
    }

    class BatteryProfile {
        <<enum>>
        REALTIME
        BALANCED
        BATTERY
        ULTRA
        +number measInterval
        +number advInterval
        +number txPower
        +number storageRate
    }

    class BLEPerf {
        +Map~string,PerfEntry~ entries
        +add(sensorId, event, bytes)
        +trackNotification(sensorId, bytes)
        +getSensorRate(sensorId) number
        +getStats() object
    }

    class IndexedDBStore {
        +IDBDatabase db
        +openDB() IDBDatabase
        +saveHistory(sensorId, data)
        +getHistory(sensorId, timeRange) DataPoint[]
        +saveFrame(sensorId, frame)
        +getFrames(sensorId) Frame[]
        +clearHistory(sensorId)
        +exportCSV(sensorId) string
    }

    class BLEConstants {
        <<constants>>
        +UUID CUSTOM_SERVICE = 0x1F10
        +UUID CUSTOM_CHAR = 0x1F1F
        +UUID OTA_SERVICE
        +UUID OTA_CHAR
        +UUID MI_TEMP_SERVICE
        +UUID MI_TEMP_CHAR
    }

    class NotificationHandler {
        +onCustomNotification(event, sensorId)
        +onMiNotification(event, sensorId)
        +parseCustomData0x33(data) TempHumiBatt
        +parseCustomHwInfo0x55(data) HwInfo
        +parseMiTempData(data) TempHumi
    }

    class AdvertParser {
        +parseAdvPVVX(mfgData) SensorReading
        +parseAdvATC1441(serviceData) SensorReading
        +parseAdvBTHome(serviceData) SensorReading
        +parseAdvMiLike(serviceData) SensorReading
        +detectFormat(data) string
    }

    class AdvertScanner {
        +startAdvertScan()
        +stopAdvertScan()
        +Strategy1_watchAdvertisements(device)
        +Strategy2_getDevices()
        +Strategy3_requestLEScan()
        +onAdvertisementReceived(event)
    }

    class FlasherSubsystem {
        +SensorState targetSensor
        +Uint8Array firmwareData
        +number flashProgress
        +flasherConnect(sensorId)
        +flasherWriteConfig(sensorId, config)
        +flasherReadConfig(sensorId)
        +onFlasherNotification(event)
        +startOTA(sensorId, firmwareBlob)
        +writeOTAChunk(offset, data)
        +verifyOTA()
    }

    class AlertSystem {
        +object thresholds
        +Map~string,number~ cooldowns
        +checkAlerts(sensors)
        +checkBatteryAlerts(sensors)
        +triggerAlert(sensorId, type, value)
        +sendNotification(title, body)
    }

    class ChartManager {
        +Chart[] charts
        +createChart(canvas, sensorId, metric)
        +updateChart(sensorId, data)
        +setTimeRange(range)
    }

    App "1" *-- "*" SensorState : sensors map
    App "1" *-- "1" BLEPerf : performance tracking
    App "1" *-- "1" IndexedDBStore : persistent storage
    App --> NotificationHandler : processes BLE data
    App --> AdvertParser : parses advertisements
    App --> AdvertScanner : passive scanning
    App --> FlasherSubsystem : firmware updates
    App --> AlertSystem : monitors thresholds
    App --> ChartManager : data visualization
    App --> BLEConstants : UUID references
    SensorState --> BatteryProfile : active profile
    NotificationHandler --> SensorState : updates readings
    AdvertParser --> SensorState : updates readings


%% === Sequence Diagram — BLE Connection + Custom Service Data ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant WB as Web Bluetooth API
    participant Dev as Mijia Sensor
    participant GATT as GATT Server
    participant CSvc as Custom Service 0x1F10
    participant CC as Custom Char 0x1F1F
    participant MSvc as Mi Temp Service
    participant MC as Mi Temp Char
    participant NH as NotificationHandler
    participant IDB as IndexedDB
    participant Alert as AlertSystem

    User->>UI: Click "Connect Sensor"
    activate UI
    UI->>WB: navigator.bluetooth.requestDevice({filters, optionalServices: [0x1F10, miTemp]})
    WB-->>User: Device picker
    User->>WB: Select sensor
    WB-->>UI: BluetoothDevice

    UI->>UI: Create SensorState for device
    UI->>GATT: device.gatt.connect()
    activate GATT
    GATT-->>UI: Server connected

    Note over UI: Try Custom Service first (PVVX firmware)

    UI->>GATT: server.getPrimaryService(0x1F10)

    alt Custom service found (PVVX firmware)
        GATT-->>UI: Custom Service
        UI->>CSvc: service.getCharacteristic(0x1F1F)
        CSvc-->>UI: customChar
        UI->>CC: customChar.startNotifications()
        CC-->>UI: Notifications enabled
        UI->>CC: addEventListener("characteristicvaluechanged", onCustomNotification)
        Note over UI: sensor.isCustom = true

        loop Continuous notifications from sensor
            Dev-->>CC: Notification packet

            alt Packet type 0x33 — Sensor data
                CC-->>UI: onCustomNotification(event)
                UI->>NH: parseCustomData0x33(data)
                NH-->>UI: {temp, humi, batt, battMv}
                UI->>UI: Update sensor.temp, sensor.humi, sensor.batt
                UI->>IDB: saveHistory(sensorId, {temp, humi, batt, timestamp})
                UI->>Alert: checkAlerts(sensors)

                alt Humidity or temperature out of range
                    Alert->>Alert: Check cooldown timers
                    alt Cooldown expired
                        Alert->>UI: triggerAlert(sensorId, type, value)
                        UI-->>User: Browser notification + UI warning
                    end
                end

                UI->>UI: render()
                UI-->>User: Updated temp/humi/battery display

            else Packet type 0x55 — Hardware info
                CC-->>UI: onCustomNotification(event)
                UI->>NH: parseCustomHwInfo0x55(data)
                NH-->>UI: {firmware, mac, measInterval, advInterval, txPower}
                UI->>UI: Update sensor metadata
            end
        end

    else Custom service NOT found — try Mi Temp service
        GATT-->>UI: Service not found error
        UI->>GATT: server.getPrimaryService(miTempServiceUUID)

        alt Mi Temp service found
            GATT-->>UI: Mi Temp Service
            UI->>MSvc: service.getCharacteristic(miTempCharUUID)
            MSvc-->>UI: miTempChar
            UI->>MC: miTempChar.startNotifications()
            MC-->>UI: Notifications enabled
            UI->>MC: addEventListener("characteristicvaluechanged", onMiNotification)
            Note over UI: sensor.isCustom = false

            loop Continuous Mi notifications
                Dev-->>MC: Notification: temp + humi data
                MC-->>UI: onMiNotification(event)
                UI->>NH: parseMiTempData(data)
                NH-->>UI: {temp, humi}
                UI->>UI: Update sensor readings
                UI->>IDB: saveHistory()
                UI->>Alert: checkAlerts()
                UI-->>User: Display updated
            end

        else No compatible service
            GATT-->>UI: Service not found
            UI->>GATT: server.disconnect()
            deactivate GATT
            UI-->>User: "Incompatible device" error
        end
    end

    deactivate UI


%% === Sequence Diagram — Advertisement Scanning (Passive Mode) ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant AS as AdvertScanner
    participant WB as Web Bluetooth API
    participant S1 as Sensor 1 (paired)
    participant S2 as Sensor 2 (paired)
    participant S3 as Sensor 3 (nearby)
    participant AP as AdvertParser

    User->>UI: Click "Start Advert Scan"
    activate UI
    UI->>AS: startAdvertScan()
    activate AS

    Note over AS: Strategy 1: watchAdvertisements on connected devices

    loop For each connected sensor
        AS->>S1: device.watchAdvertisements()
        S1-->>AS: Watching started
        AS->>S1: addEventListener("advertisementreceived", handler)
    end

    Note over AS: Strategy 2: getDevices() for paired but disconnected

    AS->>WB: navigator.bluetooth.getDevices()
    WB-->>AS: [device1, device2, ...]

    loop For each paired device
        AS->>S2: device.watchAdvertisements()
        S2-->>AS: Watching started
        AS->>S2: addEventListener("advertisementreceived", handler)
    end

    Note over AS: Strategy 3: requestLEScan fallback (if supported)

    AS->>WB: navigator.bluetooth.requestLEScan({acceptAllAdvertisements: true})

    alt requestLEScan supported
        WB-->>AS: Scan started
        AS->>WB: addEventListener("advertisementreceived", handler)
    else Not supported
        Note over AS: Skip Strategy 3
    end

    loop Advertisements received
        S1-->>AS: advertisementreceived event
        AS->>AS: Extract manufacturerData / serviceData

        AS->>AP: detectFormat(data)

        alt PVVX format detected
            AP->>AP: parseAdvPVVX(mfgData)
            AP-->>AS: {temp, humi, batt, battMv, counter, flags}
        else ATC1441 format
            AP->>AP: parseAdvATC1441(serviceData)
            AP-->>AS: {temp, humi, batt}
        else BTHome v2 format
            AP->>AP: parseAdvBTHome(serviceData)
            AP-->>AS: {temp, humi, batt, ...objects}
        else Mi-Like format
            AP->>AP: parseAdvMiLike(serviceData)
            AP-->>AS: {temp, humi}
        else Unknown format
            AP-->>AS: null (skip)
        end

        alt Data parsed successfully
            AS->>UI: Update sensor readings
            UI->>UI: sensor.temp, sensor.humi, sensor.batt updated
            UI->>UI: sensor.rssi updated from event
            UI->>UI: render()
            UI-->>User: Passive sensor data displayed
        end

        S2-->>AS: advertisementreceived event
        Note over AS: Same parsing flow

        S3-->>AS: advertisementreceived (via requestLEScan)
        Note over AS: Same parsing flow
    end

    deactivate AS
    deactivate UI

    User->>UI: Click "Stop Advert Scan"
    UI->>AS: stopAdvertScan()
    AS->>WB: Abort scan / remove listeners


%% === Sequence Diagram — Firmware Flasher (OTA) ===
sequenceDiagram
    participant User
    participant UI as App UI
    participant FL as FlasherSubsystem
    participant GATT as GATT Server
    participant OC as OTA Characteristic
    participant CC as Custom Char 0x1F1F
    participant Dev as Sensor Device

    User->>UI: Select sensor + firmware file
    User->>UI: Click "Flash Firmware"
    activate UI

    UI->>FL: flasherConnect(sensorId)
    FL->>GATT: Ensure connected via GATT
    FL->>GATT: Get OTA service + characteristic
    GATT-->>FL: OTA char reference
    FL->>OC: startNotifications()
    OC-->>FL: Notifications enabled
    FL->>OC: addEventListener("characteristicvaluechanged", onFlasherNotification)

    UI->>FL: flasherReadConfig(sensorId)
    FL->>CC: Write config read command
    Dev-->>CC: Config data notification
    CC-->>FL: onFlasherNotification(current config)
    FL-->>UI: Display current firmware config

    User->>UI: Confirm flash
    UI->>FL: startOTA(sensorId, firmwareBlob)
    activate FL

    FL->>FL: Parse firmware binary, validate header
    FL->>OC: Write OTA start command
    OC->>Dev: OTA start
    Dev-->>OC: ACK
    OC-->>FL: onFlasherNotification(ACK)

    loop For each firmware chunk (16-byte blocks)
        FL->>OC: writeOTAChunk(offset, chunkData)
        OC->>Dev: OTA data block
        Dev-->>OC: ACK with status
        OC-->>FL: onFlasherNotification(status)
        FL->>FL: flashProgress += chunkSize
        FL-->>UI: Progress update
        UI-->>User: Progress bar updated
    end

    FL->>OC: Write OTA complete command
    OC->>Dev: OTA finalize
    Dev-->>OC: Verification result
    OC-->>FL: onFlasherNotification(verify result)

    alt Verification OK
        FL->>FL: verifyOTA() success
        FL-->>UI: Flash complete
        UI-->>User: "Firmware updated successfully"
        Note over Dev: Sensor reboots with new firmware
    else Verification failed
        FL-->>UI: Flash error
        UI-->>User: "Flash verification failed"
    end

    deactivate FL
    deactivate UI


