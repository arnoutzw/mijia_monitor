%% === State Diagram ===
stateDiagram-v2
    [*] --> NoSensors

    state NoSensors {
        [*] --> WaitingForConnect
    }

    NoSensors --> Connecting : User clicks Connect

    state Connecting {
        [*] --> RequestDevice
        RequestDevice --> GATTConnect : Device selected
        GATTConnect --> TryCustomService : GATT connected

        state TryCustomService {
            [*] --> DiscoverCustom
            DiscoverCustom --> CustomFound : 0x1F10 found
            DiscoverCustom --> TryMiService : Not found
        }

        state TryMiService {
            [*] --> DiscoverMi
            DiscoverMi --> MiFound : Mi Temp found
            DiscoverMi --> IncompatibleDevice : Not found
        }

        CustomFound --> NotifySetup : Char 0x1F1F discovered
        MiFound --> NotifySetup : Mi Temp char discovered
    }

    NotifySetup --> ActiveSensor : Notifications enabled

    state ActiveSensor {
        [*] --> ReceivingData

        state ReceivingData {
            [*] --> WaitingNotification
            WaitingNotification --> ProcessingPacket : BLE notification
            ProcessingPacket --> CheckingAlerts : Data parsed
            CheckingAlerts --> SavingHistory : Alerts evaluated
            SavingHistory --> UpdatingUI : IndexedDB saved
            UpdatingUI --> WaitingNotification : Render complete
        }
    }

    ActiveSensor --> Disconnected : BLE disconnect

    state Disconnected {
        [*] --> SensorOffline
        SensorOffline --> Connecting : User reconnects
        SensorOffline --> NoSensors : User removes sensor
    }

    IncompatibleDevice --> NoSensors : Error shown
    Connecting --> Disconnected : Connection error

    state AdvertMode {
        [*] --> ScanStarting

        state ScanStarting {
            [*] --> WatchConnected
            WatchConnected --> GetPairedDevices : Strategy 1 done
            GetPairedDevices --> TryRequestLEScan : Strategy 2 done
            TryRequestLEScan --> ScanActive : Strategy 3 attempted
        }

        state ScanActive {
            [*] --> ListeningAdverts
            ListeningAdverts --> ParsingAdvert : Advertisement received
            ParsingAdvert --> DetectingFormat : Raw data extracted

            state DetectingFormat {
                [*] --> CheckPVVX
                CheckPVVX --> ParsePVVX : PVVX match
                CheckPVVX --> CheckATC : No match
                CheckATC --> ParseATC : ATC1441 match
                CheckATC --> CheckBTHome : No match
                CheckBTHome --> ParseBTHome : BTHome match
                CheckBTHome --> CheckMiLike : No match
                CheckMiLike --> ParseMiLike : Mi-Like match
                CheckMiLike --> DiscardAdvert : Unknown format
            }

            ParsePVVX --> UpdateSensor : Data extracted
            ParseATC --> UpdateSensor : Data extracted
            ParseBTHome --> UpdateSensor : Data extracted
            ParseMiLike --> UpdateSensor : Data extracted
            UpdateSensor --> ListeningAdverts : Continue scanning
            DiscardAdvert --> ListeningAdverts : Skip
        }
    }

    NoSensors --> AdvertMode : Start passive scan
    ActiveSensor --> AdvertMode : Start advert scan (parallel)
    AdvertMode --> NoSensors : Stop scan

    state FlasherMode {
        [*] --> FlasherIdle
        FlasherIdle --> ReadingConfig : Read config
        ReadingConfig --> FlasherIdle : Config displayed
        FlasherIdle --> WritingConfig : Write config
        WritingConfig --> FlasherIdle : Config saved
        FlasherIdle --> OTAFlashing : Start OTA

        state OTAFlashing {
            [*] --> OTAStart
            OTAStart --> WritingChunks : Start command ACK
            WritingChunks --> WritingChunks : Next chunk
            WritingChunks --> Verifying : All chunks sent
            Verifying --> OTAComplete : Verify OK
            Verifying --> OTAFailed : Verify failed
        }
    }

    ActiveSensor --> FlasherMode : Open flasher for sensor
    FlasherMode --> ActiveSensor : Close flasher
